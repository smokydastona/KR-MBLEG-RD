{
	"format_version": "1.8.0",
	"animations": {
		"animation.moogloom.idle": {
			"loop": true,
			"animation_length": 1.0,
			"bones": {
				"head": {
					"rotation": [
						"-query.target_x_rotation + math.sin(query.anim_time * 60) * 2",
						"-query.target_y_rotation",
						0
					]
				}
			}
		},
		"animation.moogloom.walk": {
			"loop": true,
			"animation_length": 0.8,
			"bones": {
				"front_left_leg": {
					"rotation": ["math.sin(query.anim_time * 12) * 30", 0, 0]
				},
				"back_right_leg": {
					"rotation": ["math.sin(query.anim_time * 12) * 30", 0, 0]
				},
				"front_right_leg": {
					"rotation": ["math.sin(query.anim_time * 12 + 3.14) * 30", 0, 0]
				},
				"back_left_leg": {
					"rotation": ["math.sin(query.anim_time * 12 + 3.14) * 30", 0, 0]
				},
				"head": {
					"rotation": ["-query.target_x_rotation", "-query.target_y_rotation", 0]
				}
			}
		}
	}
}
