{
  "format_version": "1.20.0",
  "animations": {
    "animation.spiral_strider.idle": {
      "loop": true,
      "bones": {
        "body": { "rotation": [0, "math.sin(query.anim_time * 1.2) * 2", 0] }
      }
    },
    "animation.spiral_strider.walk": {
      "loop": true,
      "bones": {
        "leg_front_left": { "rotation": ["math.sin(query.walk_cycle * 60) * 20", 0, 0] },
        "leg_front_right": { "rotation": ["math.sin(query.walk_cycle * 60 + 180) * 20", 0, 0] },
        "leg_back_left": { "rotation": ["math.sin(query.walk_cycle * 60 + 180) * 20", 0, 0] },
        "leg_back_right": { "rotation": ["math.sin(query.walk_cycle * 60) * 20", 0, 0] }
      }
    }
  }
}
