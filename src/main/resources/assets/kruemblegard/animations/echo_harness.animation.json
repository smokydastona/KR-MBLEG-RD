{
  "format_version": "1.20.0",
  "animations": {
    "animation.echo_harness.idle": {
      "loop": true,
      "bones": {
        "torso": { "rotation": [0, "math.sin(query.anim_time * 1.5) * 2", 0] }
      }
    },
    "animation.echo_harness.walk": {
      "loop": true,
      "bones": {
        "leg_left": { "rotation": ["math.sin(query.walk_cycle * 60) * 25", 0, 0] },
        "leg_right": { "rotation": ["math.sin(query.walk_cycle * 60 + 180) * 25", 0, 0] },
        "arm_left": { "rotation": ["math.sin(query.walk_cycle * 60 + 180) * 15", 0, 0] },
        "arm_right": { "rotation": ["math.sin(query.walk_cycle * 60) * 15", 0, 0] }
      }
    },
    "animation.echo_harness.move": {
      "loop": true,
      "bones": {
        "leg_left": { "rotation": ["math.sin(query.walk_cycle * 60) * 25", 0, 0] },
        "leg_right": { "rotation": ["math.sin(query.walk_cycle * 60 + 180) * 25", 0, 0] },
        "arm_left": { "rotation": ["math.sin(query.walk_cycle * 60 + 180) * 15", 0, 0] },
        "arm_right": { "rotation": ["math.sin(query.walk_cycle * 60) * 15", 0, 0] }
      }
    },
    "animation.echo_harness.zombie_manifest": {
      "loop": false,
      "animation_length": 1.4,
      "bones": {
        "*": {
          "scale": [
            "math.lerp(0.05, 1, query.anim_time / 1.4)",
            "math.lerp(0.05, 1, query.anim_time / 1.4)",
            "math.lerp(0.05, 1, query.anim_time / 1.4)"
          ],
          "rotation": [
            "math.sin(query.anim_time * 300) * 12",
            "math.sin(query.anim_time * 260) * 12",
            "math.sin(query.anim_time * 280) * 12"
          ]
        }
      }
    }
  }
}
