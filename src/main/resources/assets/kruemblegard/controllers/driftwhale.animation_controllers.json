{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.driftwhale.main": {
      "initial_state": "default",
      "states": {
        "default": {
          "animations": [
            "animation.driftwhale.idle",
            "animation.driftwhale.breathe"
          ],
          "transitions": [
            { "moving": "query.is_moving" }
          ]
        },
        "moving": {
          "animations": [
            "animation.driftwhale.move",
            "animation.driftwhale.breathe"
          ],
          "transitions": [
            { "default": "!query.is_moving" }
          ]
        }
      }
    }
  }
}
