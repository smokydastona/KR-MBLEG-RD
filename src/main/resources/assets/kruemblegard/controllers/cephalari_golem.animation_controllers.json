{
  "format_version": "1.8.0",
  "animation_controllers": {
    "controller.animation.cephalari_golem.moveController": {
      "states": {
        "default": {
          "animations": [
            "animation.cephalari_golem.idle_passive"
          ],
          "transitions": [
            { "offering_flower": "query.is_offering_flower" },
            { "walking": "query.is_moving" },
            { "angry_walking": "query.is_moving && query.has_target" },
            { "angry_idle": "query.has_target" }
          ]
        },
        "offering_flower": {
          "animations": [
            "animation.cephalari_golem.offer_flower"
          ],
          "transitions": [
            { "angry_walking": "query.is_moving && query.has_target" },
            { "angry_idle": "query.has_target" },
            { "walking": "query.is_moving" },
            { "default": "!query.is_moving && !query.is_offering_flower" }
          ]
        },
        "walking": {
          "animations": [
            "animation.cephalari_golem.move_passive"
          ],
          "transitions": [
            { "offering_flower": "query.is_offering_flower" },
            { "angry_walking": "query.has_target" },
            { "default": "!query.is_moving" }
          ]
        },
        "angry_idle": {
          "animations": [
            "animation.cephalari_golem.idle_angry"
          ],
          "transitions": [
            { "angry_walking": "query.is_moving && query.has_target" },
            { "offering_flower": "query.is_offering_flower && !query.has_target" },
            { "walking": "query.is_moving && !query.has_target" },
            { "default": "!query.has_target && !query.is_moving && !query.is_offering_flower" }
          ]
        },
        "angry_walking": {
          "animations": [
            "animation.cephalari_golem.move_angry"
          ],
          "transitions": [
            { "angry_idle": "!query.is_moving && query.has_target" },
            { "offering_flower": "!query.has_target && query.is_offering_flower" },
            { "walking": "query.is_moving && !query.has_target" },
            { "default": "!query.has_target && !query.is_moving && !query.is_offering_flower" }
          ]
        }
      }
    },
    "controller.animation.cephalari_golem.actionController": {
      "states": {
        "default": {
          "animations": [],
          "transitions": [
            { "attacking": "query.is_attacking" }
          ]
        },
        "attacking": {
          "animations": [
            "animation.cephalari_golem.attack"
          ],
          "transitions": [
            { "default": "query.animation_finished" }
          ],
          "transitions": []
        }
      }
    }
  }
}
