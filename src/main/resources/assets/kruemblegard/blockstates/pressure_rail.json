{
  "multipart": [
    {
      "when": { "facing": "north" },
      "apply": { "model": "kruemblegard:block/pressure_rail" }
    },
    {
      "when": { "facing": "east" },
      "apply": { "model": "kruemblegard:block/pressure_rail", "y": 90 }
    },
    {
      "when": { "facing": "south" },
      "apply": { "model": "kruemblegard:block/pressure_rail", "y": 180 }
    },
    {
      "when": { "facing": "west" },
      "apply": { "model": "kruemblegard:block/pressure_rail", "y": 270 }
    }
  ]
}
